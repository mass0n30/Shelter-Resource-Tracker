// This is your Prisma schema file,
// learn more about it in the docs: https://pris.lqwey/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id
  sid       String   @unique
  data      String   
  expiresAt DateTime
}

model UpdateData {
  id        Int      @id @default(autoincrement())
  data      String   
  createdAt DateTime @default(now())
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum ClientStatus {
  ENROLLED
  WC  // Winter Contigency
  INACTIVE
  // HOUSED ?
}

enum ReferralStatus {
  INQUIRED
  REFERRED
  PENDING
  ENROLLED
  COMPLETED
  CLOSED
  // HOUSED
  // ECT.
}

enum ResourceType {
  HOUSING
  EMPLOYMENT
  MEDICAL
  LEGAL
  SUBSTANCE_USE
  FINANCIAL_ASSISTANCE
  OTHER
}

model User {
  id         Int       @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String    @unique
  password   String
  role       UserRole  @default(STAFF)

  notes      Note[]
  referrals  Referral[] @relation("ReferralCreatedBy")

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// Additional fields will be added (phone/address/ ect)
model Client {
  id            Int           @id @default(autoincrement())
  clientId      Int?          @unique
  firstName     String
  lastName      String
  gender        String?
  status        ClientStatus  @default(ENROLLED)
  bedLabel      String?

  intakeDate    DateTime?
  outtakeDate   DateTime?     
  lastStayDate  DateTime?     @default(now())
  hereLastNight Boolean       @default(false)
  extensionStatus     Boolean       @default(false)

  // Input text or a selection input, not sure yet, need to discuss further with the team
  priorityNeed  String?
  avatarUrl     String?

  referrals     Referral[]    
  notes         Note[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Referral {
  id               Int             @id @default(autoincrement())
  clientId         Int
  createdById      Int?

  // may add resource model instead ? 
  organizationName String
  resourceType     ResourceType
  // Client's reason for referral, can be a selection input or a text input, need to discuss further with the team
  purpose          String? // or just Note

  status           ReferralStatus  @default(INQUIRED)

//release of information
  roiSigned        Boolean         @default(false)
  roiSignedAt      DateTime?

  followUpDate     DateTime?
  isPriority       Boolean         @default(false)
  closedAt         DateTime?

//additional input field for reporting and tracking
  summary          String?
  // contact info for resource ?

  client           Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy        User?           @relation("ReferralCreatedBy", fields: [createdById], references: [id])

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Note {
  id         Int       @id @default(autoincrement())
  clientId   Int?      //if no clientId is provided, it's a dashboard note, not associated with any specific client
  authorId   Int       
  content    String
  setReminder Boolean   @default(false)
  reminderAt DateTime?
  visibility String?   @default("private") // "private" or "public"

  client     Client?    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author     User?      @relation(fields: [authorId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Notification {
  id          Int       @id @default(autoincrement())
  type        String
  message     String
  data        Json      @default("{}")

  createdAt   DateTime  @default(now())
  read        Boolean   @default(false)
}
